@using GridCore
@using GridMvc
@addTagHelper *, GridMvc
@model PersonalViewModel

<div class="row" style="margin-top: 2rem; margin-bottom: 3rem;">
    <div style="font-size: 2.5rem; font-weight: 750; color: var(--text-title-color);
        display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">

        <a asp-controller="Personal" asp-action="Index" style="flex-shrink: 0;">
            <img src="img/logoNCO.png" alt="" style="width: 9rem;" />
        </a>
        <span class="name" style="flex: 1; text-align: center; min-width: 200px;">
            Formulario de Ingreso
        </span>
        <!-- Espaciador invisible para centrar el título correctamente en pantallas grandes -->
        <div style="width: 9rem; flex-shrink: 0;"></div>
    </div>
</div>

@using (Html.BeginForm("Create", "Personal", FormMethod.Post))
{
    <div class="row">
        <div class="form-group col-md-2">
            <label for="rutUsuario">Rut</label>
            @Html.TextBoxFor(m => m.RutPersonal, new { @class = "form-control" })
            @Html.ValidationMessageFor(m => m.RutPersonal, "", new { @class = "text-danger" })
        </div>
        <div class="form-group col-md-6">
            <label for="idUsuario">Nombre</label>
            @Html.TextBoxFor(m => m.NombrePersonal, new { @class = "form-control" })
            @Html.ValidationMessageFor(m => m.NombrePersonal, "", new { @class = "text-danger" })
        </div>
    </div>
    <br />
    <div class="row">
        <div class="form-group col-md-6">
            <label for="nombrePersona">Ap. Paterno</label>
            @Html.TextBoxFor(m => m.ApPaternoPersonal, new { @class = "form-control", required = "required" })
            @Html.ValidationMessageFor(m => m.ApPaternoPersonal, "", new { @class = "text-danger" })
        </div>
        <div class="form-group col-md-6">
            <label for="apellidoPaterno">Ap. Materno</label>
            @Html.TextBoxFor(m => m.ApMaternoPersonal, new { @class = "form-control", required = "required" })
        </div>
    </div>
    <br />
    <div class="row">
        <div class="form-group col-md-6">
            <label for="IdRegion">Región</label>
            @Html.DropDownListFor(m => m.IdRegion,
                new SelectList(Model.regionEntities, "IdRegion", "NombreRegion"),
                "Seleccione una Región",
                new { @class = "form-control" })
            @Html.ValidationMessageFor(m => m.IdRegion, "", new { @class = "text-danger" })
        </div>
        <div class="form-group col-md-6">
            <label for="IdComuna">Comuna</label>
            @Html.DropDownListFor(m => m.IdComuna,
                ViewBag.ListaComuna as List<SelectListItem>,
                "Seleccione una Comuna",
                new { @class = "form-control" })
            @Html.ValidationMessageFor(m => m.IdComuna, "", new { @class = "text-danger" })
        </div>
    </div>
    <br />
    <div class="row">
        <div class="form-group col-md-6">
            <label for="apellidoMaterno">Teléfono</label>
            @Html.TextBoxFor(m => m.TelefonoPersonal, new { @class = "form-control", required = "required" })
            @Html.ValidationMessageFor(m => m.TelefonoPersonal, "", new { @class = "text-danger" })
        </div>
        <div class="form-group col-md-6">
            <label for="correoElectronico">E-Mail</label>
            @Html.TextBoxFor(m => m.CorreoElectronico, new { @class = "form-control", required = "required" })
            @Html.ValidationMessageFor(m => m.CorreoElectronico, "", new { @class = "text-danger" })
        </div>
    </div>
    <br />
    <br />
    <div class="row">
        <h4>Edad e Hijos</h4>

        <div class="row">
            <div class="form-group col-md-2">
                <label for="nombreHijo">Nombre Hijo</label>
                @Html.TextBoxFor(m => m.NombreHijo, new { @class = "form-control" })
            </div>
            <div class="form-group col-md-3">
                <label for="edadHijo">Edad</label>
                @Html.TextBoxFor(m => m.EdadHijo, new { @class = "form-control" })
            </div>
            <div class="form-group col-md-3 d-flex align-items-end">
                <button type="button" id="btnAgregarHijo" class="btn btn-primary">
                    Agregar
                </button>
            </div>
        </div>

        <!-- Grilla -->
        <table id="tablaHijo" class="table table-bordered table-striped">
            <thead class="table-dark">
                <tr>
                    <th>Nombre Hijo</th>
                    <th>Edad</th>
                    <th>Acción</th>
                </tr>
            </thead>
            <tbody>
                <!-- Las filas se agregan aquí dinámicamente -->
            </tbody>
        </table>
    </div>
    <br />
    <br />
    <div class="row">
        <h4>Tipos de Licencias</h4>

        <div class="row">
            <div class="form-group col-md-2">
                <label for="fecOtorgamiento">Fecha Otorgamiento</label>
                @Html.TextBoxFor(m => m.FecOtorgamiento, new { @class = "form-control" })
            </div>
            <div class="form-group col-md-2">
                <label for="fecVctoLicencia">Fecha Vcto. Licencia</label>
                @Html.TextBoxFor(m => m.FechaVctoLicencia, new { @class = "form-control" })
            </div>
            <div class="form-group col-md-3">
                <label for="fecLicencia">Clase Licencia Conducir</label>
                @Html.DropDownList("ddlTipoLicencia", new SelectList(Model.tipoLicenciaEntities, "IdTipoLicencia", "NombreTipo"), "Seleccione una Licencia", new { @class = "form-control" })
            </div>
            <div class="form-group col-md-3 d-flex align-items-end">
                <button type="button" id="btnAgregar" class="btn btn-primary">
                    Agregar
                </button>
            </div>
        </div>

        <!-- Grilla -->
        <table id="tablaLicencias" class="table table-bordered table-striped">
            <thead class="table-dark">
                <tr>
                    <th>Fecha Otorgamiento</th>
                    <th>Fecha Vencimiento</th>
                    <th>Tipo de Licencia</th>
                    <th>Acción</th>
                </tr>
            </thead>
            <tbody>
                <!-- Las filas se agregan aquí dinámicamente -->
            </tbody>
        </table>
    </div>
    <br />
    <br />
    <div class="row">
        <h4>Documentación</h4>
        <div class="row">
            @await Html.Grid(Model.tipoDocumentoEntities).Named("gridTipoDocumento").Columns(c =>
            {
                c.Add(model => model.IdTipoDocumento, true);
                c.Add(model => model.NombreTipoDocumento).Titled("Nombre").SetWidth(20);
                c.Add()
                .Encoded(false)
                .Sanitized(false)
                .SetWidth(30)
                .Titled("Archivo")
                .RenderValueAs(o => $"<input type='file' class='form-control file-documento' " +
                    $"data-id='{o.IdTipoDocumento}' " +
                    $"data-nombre='{o.NombreTipoDocumento}' " +
                    $"{(o.NombreTipoDocumento!.Trim().ToUpper() == "REGISTRO SOCIAL DE HOGAR" ? "data-excluir='true'" : "")} />");
            }).WithPaging(20).EmptyText("No se encontraron registros").RenderAsync()
        </div>
    </div>

    <!-- Contenedor de hidden inputs DENTRO del form -->
    <div id="hiddenContainerPersonalTipoLicencia"></div>
    <div id="hiddenContainerPersonalHijo"></div>
    <!-- ✅ Contenedor donde se renderiza el PartialView Mensajeria -->
    <div id="resultadoMensaje"></div>
    <button type="button" id="btnGrabar" name="btnGrabar" class="btn btn-info" style="margin-top: 2rem;">Enviar</button>
}

@section Scripts {
    <script>
        var getComuna_Url = '@Url.Action("GetComuna", "Personal")';
        var validarRut_Url = '@Url.Action("ValidarRut", "Personal")';
    </script>
    <script src="~/js/Formulario.js" asp-append-version="true"></script>
    <script src="~/js/funcionesBasicas.js" asp-append-version="true"></script>
}

