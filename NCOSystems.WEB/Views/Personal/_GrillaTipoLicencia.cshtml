@using GridMvc
@using NCOSystems.Entity.Parametro
@using NCOSystems.Entity.Personal
@model List<PersonalTipoLicencia>

@await Html.Grid(Model).Named("gridTipoLicencia").Columns(c =>
{
    c.Add(model => model.FechaVctoLicencia).Titled("Fecha Vcto Licencia").SetWidth(150).Format("{0:dd/MM/yyyy}");
    c.Add(model => model.NombreClaseLicencia).Titled("Nombre").SetWidth(150);
    c.Add()
    .Encoded(false)
    .Sanitized(false)
    .SetWidth(30)
    .RenderValueAs(o => $"<button type='button' id='btnQuitarFila' name='btnQuitarFila' class='btn btn-info' onclick='eliminarFila({o.IdPersonalTipoLicencia})'>Quitar</button>");
}).WithPaging(20).EmptyText("No se encontraron registros").RenderAsync()

