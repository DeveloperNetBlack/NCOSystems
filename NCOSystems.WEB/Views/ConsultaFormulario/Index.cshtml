@using GridCore
@using GridMvc
@addTagHelper *, GridMvc
@model PersonalViewModel

<div class="row" style="margin-top: 2rem; margin-bottom: 3rem;">
    <div style="font-size: 2.5rem; font-weight: 750; color: var(--text-title-color);
        display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">

        <a asp-controller="ConsultaFormulario" asp-action="Index" style="flex-shrink: 0;">
            <img src="~/img/logoNCO.png" alt="" style="width: 9rem;" />
        </a>
        <span class="name" style="flex: 1; text-align: center; min-width: 200px;">
            Consulta Formulario de Ingreso
        </span>
        <!-- Espaciador invisible para centrar el título correctamente en pantallas grandes -->
        <div style="width: 9rem; flex-shrink: 0;"></div>
    </div>
</div>

@using (Html.BeginForm("Listar", "ConsultaFormulario", FormMethod.Post))
{
    <div class="row">
        <div class="form-group col-md-2">
            <label for="rutUsuario">Rut</label>
            @Html.TextBoxFor(m => m.RutPersona, new { @class = "form-control" })
        </div>
        <div class="form-group col-md-6">
            <label for="idUsuario">Nombre</label>
            @Html.TextBoxFor(m => m.NombrePersonaCompleto, new { @class = "form-control" })
        </div>
        <div class="form-group col-md-1 d-flex justify-content-center">
            <button class="btn btn-info" type="submit">
                Buscar
            </button>
        </div>
    </div>
    <br />
    <div class="row">
        <div class="row">
            @await Html.Grid(Model.ListaPersonal).Named("gridTipoDocumento").Columns(c =>
            {
                c.Add(model => model.RutPersonal).Titled("Rut").SetWidth(5);
                c.Add(model => model.NombreCompletoPersonal).Titled("Nombre").SetWidth(20);
                c.Add()
                .Encoded(false)
                .Sanitized(false)
                .SetWidth(30)
                .Titled("Detalle")
                .RenderValueAs(o => $"<b><a class='modal_link' href='/ConsultaFormulario/GetPersonal?rutPersonal={o.RutPersonal}'>Ver</a></b>");
            }).WithPaging(20).EmptyText("No se encontraron registros").RenderAsync()
        </div>
    </div>
}

@section Scripts {
    <script>
         // ==========================================
        // Validación RUT
        // ==========================================
        $("#RutPersona").Rut({
            on_error: function () {
                alert('Rut incorrecto');
            },
            format_on: 'keyup'
        });
    </script>
}

