@using GridCore
@using GridMvc
@addTagHelper *, GridMvc
@model PersonalViewModel

@{
    Layout = "_Layout";
}

<div class="row" style="margin-top: 2rem; margin-bottom: 3rem;">

    <div style="font-size: 2.5rem; font-weight: 750; color: var(--text-title-color);
        display: flex; justify-content: center; align-items: center; position: relative;">
        
        <a asp-controller="Personal" asp-action="Index" style="position: absolute; left: 0;">
            <img src="img/logoNCO.png" alt="" style="width: 9rem;" />
        </a>

        <span class="name">
            Consulta Formulario de Ingreso
        </span>

    </div>

</div>

@using (Html.BeginForm("Create", "Personal", FormMethod.Post))
{
    <div class="row">
        <div class="form-group col-md-2">
            <label for="rutUsuario">Rut</label>
            @Html.TextBoxFor(m => m.RutPersonal, new { @class = "form-control" })
        </div>
        <div class="form-group col-md-6">
            <label for="idUsuario">Nombre</label>
            @Html.TextBoxFor(m => m.NombrePersonal, new { @class = "form-control" })
        </div>
    </div>
    <div class="row">
        <div class="form-group col-md-6">
            <label for="nombrePersona">Ap. Paterno</label>
            @Html.TextBoxFor(m => m.ApPaternoPersonal, new { @class = "form-control" })
        </div>
        <div class="form-group col-md-6">
            <label for="apellidoPaterno">Ap. Materno</label>
            @Html.TextBoxFor(m => m.ApMaternoPersonal, new { @class = "form-control" })
        </div>
    </div>
@*     <div class="row">
        <div class="form-group col-md-6">
            <label for="apellidoMaterno">Región</label>
            @Html.DropDownList("ddlRegion", new SelectList(Model.regionEntities, "IdRegion", "NombreRegion"), "Seleccione una Región", new { @class = "form-control" })
        </div>
        <div class="form-group col-md-6">
            <label for="correoElectronico">Comuna</label>
            @Html.DropDownList("ddlComuna", ViewBag.ListaComuna as List<SelectListItem>, "Seleccione una Comuna", new { @class = "form-control" })
        </div>
    </div> *@
    <div class="row">
        <div class="form-group col-md-6">
            <label for="apellidoMaterno">Teléfono</label>
            @Html.TextBoxFor(m => m.TelefonoPersonal, new { @class = "form-control" })
        </div>
        <div class="form-group col-md-6">
            <label for="correoElectronico">E-Mail</label>
            @Html.TextBoxFor(m => m.CorreoElectronico, new { @class = "form-control" })
        </div>
    </div>
    <br />
    <br />
    <div class="row">
        <h4>Edad e Hijos</h4>
        <div class="row">
            @await Html.Grid(Model.personalHijoEntities).Named("gridTipoDocumento").Columns(c =>
            {
                c.Add(model => model.NombreHijo).Titled("Nombre Hijo").SetWidth(10);
                c.Add(model => model.EdadHijo).Titled("Edad").SetWidth(5);
            }).WithPaging(20).EmptyText("No se encontraron registros").RenderAsync()
        </div>
    </div>
    <br />
    <br />
    <div class="row">
        <h4>Tipos de Licencias</h4>
        <div class="row">
            @await Html.Grid(Model.personalTipoLicenciaEntities).Named("gridTipoDocumento").Columns(c =>
            {
                c.Add(model => model.NombreClaseLicencia).Titled("Tipo Licencia").SetWidth(10);
                c.Add(model => model.FecVctoLicencia).Titled("Fec. Vcto.").SetWidth(10).Format("{0:dd/MM/yyyy}");
            }).WithPaging(20).EmptyText("No se encontraron registros").RenderAsync()
        </div>
    </div>
    <br />
    <br />
    <div class="row">
        <h4>Documentación</h4>
        <div class="row">
            @await Html.Grid(Model.documentoEntities).Named("gridTipoDocumento").Columns(c =>
            {
                c.Add(model => model.IdDocumento, true);
                c.Add(model => model.NombreTipoDocumento).Titled("Nombre Documento").SetWidth(10);
                c.Add(model => model.NombreDocumento).Titled("Nombre Archivo").SetWidth(20);
                c.Add()
                .Encoded(false)
                .Sanitized(false)
                .SetWidth(30)
                .Titled("Archivo")
                .RenderValueAs(o => $"<b><a class='modal_link' href='{o.RutaDocumento}'>{o.NombreDocumento}</a></b>");
            }).WithPaging(20).EmptyText("No se encontraron registros").RenderAsync()
        </div>
    </div>

    <button type="button" id="btnGrabar" name="btnGrabar" class="btn btn-info" style="margin-top: 2rem;">Grabar</button>
}

@section Scripts {
    <script>
        var getComuna_Url = '@Url.Action("GetComuna", "Personal")';
        var validarRut_Url = '@Url.Action("ValidarRut", "Personal")';
    </script>
    <script src="~/js/Formulario.js"></script>
    <script src="~/js/funcionesBasicas.js"></script>
}

